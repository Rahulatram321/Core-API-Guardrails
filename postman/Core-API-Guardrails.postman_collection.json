          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"authorId\": 3,\n  \"authorType\": \"USER\",\n  \"content\": \"Thanks for the follow-up.\",\n  \"parentCommentId\": 1\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/posts/{{postId}}/comments",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "posts",
            "{{postId}}",
            "comments"
          ]
        }
      }
    },
